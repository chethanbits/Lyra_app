# PyJHora API base URL (used at build time for the app).
# Leave unset to use http://localhost:8000

# For Android Emulator: the emulator sees your PC's localhost as 10.0.2.2
# Build the app with this so the app in the emulator can reach the API on your PC:
# VITE_API_URL=http://10.0.2.2:8000
# Then run: npm run android  (or set this, then npm run cap:sync and open Android Studio)

# VITE_API_URL=http://10.0.2.2:8000
